<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>1a2b3c4d-5e6f-7a8b-9c0d-e1f2a3b4c5d6</Id>
  <Version>1.2.1</Version>
  <ProviderName>Corporate Translator</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Corporate Jargon Translator" />
  <Description DefaultValue="Translates plain English into ridiculous corporate doublespeak using AI." />

  <IconUrl DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://github.com/jimdawdy-hub/outlook-corporate-translator" />

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/src/taskpane.html" />
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/src/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" MinVersion="1.1" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="CorporateTranslatorGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="TranslateButton">
                  <Label resid="TranslateButton.Label" />
                  <Supertip>
                    <Title resid="TranslateButton.Label" />
                    <Description resid="TranslateButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="CorporateTranslatorGroupCompose">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="TranslateButtonCompose">
                  <Label resid="TranslateButton.Label" />
                  <Supertip>
                    <Title resid="TranslateButton.Label" />
                    <Description resid="TranslateButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/src/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://jimdawdy-hub.github.io/outlook-corporate-translator/src/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Corporate Translator" />
        <bt:String id="TranslateButton.Label" DefaultValue="Translate to Corporate" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TranslateButton.Tooltip" DefaultValue="Transform your boring plain English into elite corporate doublespeak." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
